# IntervoxAI environment template.
# Copy this file to .env.local and set real values. Never commit .env.local.

# Firebase client SDK (public values)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase admin SDK (server-only values)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep literal \n escapes in FIREBASE_PRIVATE_KEY.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Template Generation API
TEMPLATE_GENERATION_API_KEY=your_template_gen_api_key
# Verify the model ID at: https://ai.google.dev/gemini-api/docs/models
TEMPLATE_GENERATION_MODEL="gemini-2.5-pro"

# Live Audio Conversational API
LIVE_INTERVIEW_API_KEY=your_live_interview_api_key
LIVE_INTERVIEW_MODEL="models/gemini-2.5-flash-native-audio-preview-12-2025"

# Feedback Processing API
FEEDBACK_API_KEY=your_feedback_api_key
# Verify the model ID at: https://ai.google.dev/gemini-api/docs/models
FEEDBACK_MODEL="gemini-2.5-pro"

# Resume encryption — REQUIRED (even in development).
# F-010 FIX: This is now required in all environments so encryption is always
# tested locally and there is no plaintext fallback risk.
#
# Generate a key with:
#   openssl rand -base64 32
#
# Then paste the output (including the trailing =) as the value below.
RESUME_ENCRYPTION_KEY=your_base64_32_byte_key_from_openssl_rand

# Brandfetch (public client id used in logo CDN URLs)
NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=your_brandfetch_client_id

# App settings — REQUIRED in production (used for CSRF Origin validation).
# F-011 FIX: This is required in production. Missing it disables the CSRF check.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Upstash Redis (required in production for distributed rate limits)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
