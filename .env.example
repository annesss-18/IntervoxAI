# IntervoxAI environment template.
# Copy this file to .env.local and set real values. Never commit .env.local.

# ── Maintenance bypass (TEMPORARY — remove after env rotation) ──────────────
# Set both to "true" to skip authentication and use a demo user.
# MAINTENANCE_BYPASS_MODE=true
# NEXT_PUBLIC_MAINTENANCE_BYPASS_MODE=true

# Firebase client SDK (public values)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase admin SDK (server-only values)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep literal \n escapes in FIREBASE_PRIVATE_KEY.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Firestore database ID. Defaults to "prod" if not set — this project uses a
# named database called "prod" (configured in firebase.json). If you are
# deploying your own instance with a differently-named database, set this to
# match. Firebase's auto-created first database is named "(default)", but this
# project does not use that name.
FIREBASE_DATABASE_ID=prod

# Template generation API
TEMPLATE_GENERATION_API_KEY=your_template_gen_api_key
# Verify the model ID against the current Gemini docs before changing it.
TEMPLATE_GENERATION_MODEL="gemini-2.5-pro"

# Live audio conversational API
LIVE_INTERVIEW_API_KEY=your_live_interview_api_key
LIVE_INTERVIEW_MODEL="models/gemini-2.5-flash-native-audio-preview-12-2025"

# Feedback processing API
FEEDBACK_API_KEY=your_feedback_api_key
# Verify the model ID against the current Gemini docs before changing it.
FEEDBACK_MODEL="gemini-2.5-pro"

# Resume encryption (required in every environment).
# Generate a key with: openssl rand -base64 32
#
# !! KEY ROTATION WARNING !!
# Changing this value after resumes have been stored will silently break
# decryption for ALL existing interview sessions that have a resume attached.
# AES-256-GCM auth-tag verification will fail for every ciphertext encrypted
# with the old key and decryptResumeText() will return undefined for those sessions.
#
# Before rotating this key in production you MUST:
#   1. Read all interview_sessions documents whose resumeText starts with "enc:v1:".
#   2. Decrypt each value with the OLD key.
#   3. Re-encrypt each value with the NEW key.
#   4. Write the re-encrypted values back to Firestore.
#   5. Deploy with the new key only after the migration is complete.
RESUME_ENCRYPTION_KEY=your_base64_32_byte_key_from_openssl_rand

# Brandfetch (public client id used in logo CDN URLs)
NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=your_brandfetch_client_id

# App URL — REQUIRED IN PRODUCTION.
# Must be set to the canonical URL of your deployment (e.g. https://your-domain.com).
#
# This value is used for:
#   • CSRF origin validation in API routes (withAuth / withAuthClaims middleware)
#   • QStash callback URL when publishing feedback jobs — if this is wrong or
#     missing, all queued feedback jobs will be delivered to the wrong endpoint
#     and silently fail.
#   • Links in feedback-ready email notifications.
#
# Leaving this unset in production will cause an error when the first feedback
# job is published via QStash.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Upstash Redis (required in production for distributed rate limits)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Upstash QStash (optional - enables durable feedback queue with retry + DLQ).
# Without these, feedback generation falls back to Next.js after().
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# Resend email notifications (optional - feedback emails are skipped unless both values are set).
RESEND_API_KEY=your_resend_api_key
# Use a verified Resend sender address.
RESEND_FROM_ADDRESS="IntervoxAI <noreply@your-domain.com>"