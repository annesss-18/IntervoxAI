rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Shared predicates.
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User profiles.
    match /users/{userId} {
      allow read: if isOwner(userId);
      // Writes are handled by trusted server APIs using Admin SDK.
      allow write: if false;
    }
    
    // Interview templates.
    match /interview_templates/{templateId} {
      // Public templates are readable by all; private templates by owner only.
      allow read: if resource.data.isPublic == true || 
                     isOwner(resource.data.creatorId);

      // Server-managed via Admin SDK.
      allow write: if false;
    }
    
    // Interview sessions.
    match /interview_sessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);

      // Server-managed exclusively via Admin SDK (bypasses rules).
      // Explicitly deny all client-side mutations.
      allow create, update, delete: if false;

      // Transcript chunks are owned by the parent session's user.
      match /transcript_chunks/{chunkId} {
        allow read: if isOwner(
          get(/databases/$(database)/documents/interview_sessions/$(sessionId)).data.userId
        );
        allow write: if false;
      }
    }
    
    // Interview feedback.
    match /feedback/{feedbackId} {
      // Feedback is owner-readable.
      allow read: if isOwner(resource.data.userId);

      // Server-managed via Admin SDK.
      allow write: if false;
    }
    
    // Deny all other collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
